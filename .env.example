PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_api

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Encryption — AES-256-GCM key for storing access tokens at rest (32-byte hex)
ENCRYPTION_KEY=

# JWT — secret used to sign internal API tokens
JWT_SECRET=

# SSO — Drasken custom PKCE auth
SSO_CLIENT_ID=
SSO_API_URL=https://sso.drasken.dev
SSO_ACCOUNTS_URL=https://accounts.drasken.dev

# Meta / WhatsApp Business Platform
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Webhooks
WEBHOOK_VERIFY_TOKEN=

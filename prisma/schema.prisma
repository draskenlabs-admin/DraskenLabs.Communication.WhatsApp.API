// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  owner
  admin
  member
}

model Organisation {
  id        Int         @id @default(autoincrement())
  name      String
  slug      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  members    OrgMember[]
  Waba       Waba[]
  UserApiKey UserApiKey[]
  Message    Message[]
  Contact    Contact[]
}

model OrgMember {
  id        Int      @id @default(autoincrement())
  orgId     Int
  userId    Int
  role      OrgRole  @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org  Organisation @relation(fields: [orgId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
}

model User {
  id          Int        @id @default(autoincrement())
  clerkId     String     @unique
  firstName   String
  lastName    String
  email       String     @unique
  status      Boolean    @default(true)
  activeOrgId Int?
  createdAt   DateTime   @default(now())

  UserWhatsapp UserWhatsapp[]
  UserApiKey   UserApiKey[]
  Waba         Waba[]
  Message      Message[]
  OrgMember    OrgMember[]
}

model UserWhatsapp {
  id          Int      @id @default(autoincrement())
  userId      Int
  businessId  String
  wabaId      String
  accessToken String // Encrypted (AES-256-GCM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  waba Waba @relation(fields: [wabaId], references: [wabaId])

  @@unique([userId, wabaId])
}

model Waba {
  id                       Int               @id @default(autoincrement())
  wabaId                   String            @unique
  name                     String?
  currency                 String?
  timezoneId               String?
  messageTemplateNamespace String?
  userId                   Int
  orgId                    Int
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  org             Organisation      @relation(fields: [orgId], references: [id])
  UserWhatsapp     UserWhatsapp[]
  WabaPhoneNumber  WabaPhoneNumber[]
  InboundMessage   InboundMessage[]
  MessageTemplate  MessageTemplate[]
}

model WabaPhoneNumber {
  id                     Int      @id @default(autoincrement())
  phoneNumberId          String   @unique
  verifiedName           String
  codeVerificationStatus String
  displayPhoneNumber     String
  qualityRating          String
  platformType           String
  throughputLevel        String
  lastOnboardedTime      DateTime
  wabaId                 String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  waba Waba @relation(fields: [wabaId], references: [wabaId])
}

model UserApiKey {
  id        Int      @id @default(autoincrement())
  userId    Int
  orgId     Int
  accessKey String   @unique
  secretKey String // Encrypted
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id])
  org  Organisation @relation(fields: [orgId], references: [id])
}

enum MessageType {
  text
  image
  video
  audio
  document
  template
  interactive
  location
  reaction
  contacts
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
  DELETED
  DISABLED
  IN_APPEAL
}

enum TemplateCategory {
  AUTHENTICATION
  MARKETING
  UTILITY
}

enum MessageStatus {
  sent
  delivered
  read
  failed
}

model Message {
  id            Int           @id @default(autoincrement())
  metaMessageId String?       @unique
  phoneNumberId String
  to            String
  type          MessageType
  payload       Json
  status        MessageStatus @default(sent)
  userId        Int
  orgId         Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User         @relation(fields: [userId], references: [id])
  org  Organisation @relation(fields: [orgId], references: [id])
}

model MessageTemplate {
  id             Int              @id @default(autoincrement())
  metaTemplateId String
  wabaId         String
  name           String
  language       String
  category       TemplateCategory
  status         TemplateStatus   @default(PENDING)
  components     Json
  rejectedReason String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  waba Waba @relation(fields: [wabaId], references: [wabaId])

  @@unique([wabaId, name, language])
}

model Contact {
  id        Int      @id @default(autoincrement())
  orgId     Int
  phone     String
  name      String?
  email     String?
  optedOut  Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id])

  @@unique([orgId, phone])
}

model InboundMessage {
  id            Int      @id @default(autoincrement())
  metaMessageId String   @unique
  wabaId        String
  phoneNumberId String
  from          String
  senderName    String?
  type          String
  payload       Json
  timestamp     DateTime
  createdAt     DateTime @default(now())

  waba Waba @relation(fields: [wabaId], references: [wabaId])
}

model WebhookEvent {
  id        Int      @id @default(autoincrement())
  eventType String
  wabaId    String
  payload   Json
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int            @id @default(autoincrement())
  clerkId      String         @unique
  firstName    String
  lastName     String
  email        String         @unique
  status       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  UserWhatsapp UserWhatsapp[]
  UserApiKey   UserApiKey[]
  Waba         Waba[]
}

model UserWhatsapp {
  id          Int      @id @default(autoincrement())
  userId      Int
  businessId  String
  wabaId      String
  accessToken String // Encrypted (AES-256-GCM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  waba Waba @relation(fields: [wabaId], references: [wabaId])

  @@unique([userId, wabaId])
}

model Waba {
  id                       Int               @id @default(autoincrement())
  wabaId                   String            @unique
  name                     String?
  currency                 String?
  timezoneId               String?
  messageTemplateNamespace String?
  userId                   Int
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  user                     User              @relation(fields: [userId], references: [id])
  UserWhatsapp             UserWhatsapp[]
  WabaPhoneNumber          WabaPhoneNumber[]
}

model WabaPhoneNumber {
  id                     Int      @id @default(autoincrement())
  phoneNumberId          String   @unique
  verifiedName           String
  codeVerificationStatus String
  displayPhoneNumber     String
  qualityRating          String
  platformType           String
  throughputLevel        String
  lastOnboardedTime      DateTime
  wabaId                 String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  waba Waba @relation(fields: [wabaId], references: [wabaId])
}

model UserApiKey {
  id        Int      @id @default(autoincrement())
  userId    Int
  accessKey String   @unique
  secretKey String // Encrypted
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
